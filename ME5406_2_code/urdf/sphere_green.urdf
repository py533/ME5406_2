<?xml version="1.0" ?>
<!-- local_profile: sphere object variant for project-specific dataset -->
<robot name="sphere_green_project_variant">
  <link name="baseLink">
    <contact>
      <lateral_friction value="0.55"/>
    </contact>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.0320"/>
      </geometry>
      <material name="sphere_green_local">
        <color rgba="0.14 0.76 0.24 1.00"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.0320"/>
      </geometry>
    </collision>
  </link>
</robot>
