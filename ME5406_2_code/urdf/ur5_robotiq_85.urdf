  <!-- connect arm to world -->
  <joint name="world_arm_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin rpy="0.0 0.0 0" xyz="0 0 0"/>
  </joint>


</robot>

