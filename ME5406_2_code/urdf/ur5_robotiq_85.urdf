  <link name="world"/>
  <!-- connect gripper to arm -->
  <joint name="robotiq_85_base_joint" type="fixed">
    <parent link="ee_link"/>
    <child link="robotiq_arg2f_base_link"/>
    <origin rpy="0 1.57079632679 0" xyz="0 0 0"/>
  </joint>

